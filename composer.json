{
    "name": "content-os/app",
    "description": "Built on Converge skeleton — 模块化单体·整洁架构·CI/CD·金丝雀",
    "type": "project",
    "repositories": [
        {
            "type": "path",
            "url": "../converge-core"
        }
    ],
    "require": {
        "php": ">=8.2",
        "converge/core": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Modules\\": "modules/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
